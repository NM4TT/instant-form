---
import '../styles/app.css';
import { getCollection } from 'astro:content';
import DesktopMenu from '#components/layout/DesktopMenu.svelte';
import MobileMenu from '#components/layout/MobileMenu.svelte';

interface Props {
	title?: string;
}

const formEntries = await getCollection('form');
const form = formEntries[0]?.data;
const { title } = Astro.props;
const pageTitle = title || form?.project.name || "Instant Form";
const logoUrl = form?.branding.logo_url || "/logo.svg";
const aboutTitle = form?.pages.about.title || "About";
const fonts = form?.branding.fonts;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		{fonts?.google_fonts_url && <link href={fonts.google_fonts_url} rel="stylesheet" />}
		<style define:vars={{
			displayFont: fonts?.display ? `'${fonts.display}', var(--font-display-fallback)` : 'var(--font-display-fallback)',
			sansFont: fonts?.sans ? `'${fonts.sans}', var(--font-sans-fallback)` : 'var(--font-sans-fallback)',
			monoFont: fonts?.mono ? `'${fonts.mono}', var(--font-mono-fallback)` : 'var(--font-mono-fallback)'
		}}>
			:root {
				--font-display: var(--displayFont);
				--font-sans: var(--sansFont);
				--font-mono: var(--monoFont);
			}
		</style>
	</head>
	<body>
		<main class="max-w-4xl mx-auto min-h-screen px-4">
			<header class="glass-header py-4 mb-8">
				<div class="flex justify-between items-center">
					<a href="/" class="flex items-center gap-3">
						<img src={logoUrl} alt="Logo" class="h-10 w-auto" />
						<span class="font-display font-extrabold text-xl">{form?.project.name}</span>
					</a>
					<div class="hidden md:block">
						<DesktopMenu client:load aboutTitle={aboutTitle} />
					</div>
				</div>
			</header>

			<div class="md:hidden">
				<MobileMenu client:load aboutTitle={aboutTitle} />
			</div>

			<div class="pb-20">
				<slot />
			</div>

			<footer class="py-12 border-t border-secondary/10 text-center">
				<p class="font-mono text-[10px] uppercase tracking-widest opacity-50">
					&copy; {new Date().getFullYear()} {form?.project.name}
				</p>
			</footer>
		</main>
	</body>
</html>
