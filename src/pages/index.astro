---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Layout from '#layouts/Layout.astro';
import FormContainer from '#components/form/FormContainer.svelte';

const formEntries = await getCollection('form');
const form = formEntries[0]?.data;

if (!form) {
    return Astro.redirect('/404');
}

const isMockMode = form.settings.mockMode === true;
---

<Layout>
	<div class="mt-8">
        {isMockMode && (
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 text-amber-700 text-xs font-bold uppercase tracking-wider mb-6 border border-amber-200">
                <Icon name="mdi:test-tube" class="text-sm" />
                <span>Mock Mode</span>
            </div>
        )}

		<h1 class="text-4xl md:text-5xl mb-4">{form.project.name}</h1>
		<p class="text-lg opacity-70 mb-12">{form.project.description}</p>

		<FormContainer 
            client:load 
            questions={form.questions} 
            settings={form.settings} 
            summaryConfig={form.pages.summary}
            successConfig={form.pages.success}
            failureConfig={form.pages.failure}
        />
	</div>
</Layout>
